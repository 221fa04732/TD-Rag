# Copy this file to .env and edit as needed:
# cp .env.example .env
#
# --- CORS (browser calling API from another origin, e.g. local Vite → deployed backend) ---
# Comma-separated. Defaults in code: http://localhost:5173 and http://127.0.0.1:5173
# If you open the dev UI at http://YOUR_LAN_IP:5173, add that origin too, e.g.:
# CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://192.168.10.50:5173
#
# --- Answer synthesis (Gemini) ---
# Get a key at https://ai.google.dev/
# GEMINI_API_KEY=your-gemini-api-key-here
#
# --- Image explanations (optional, separate key; vision model) ---
# After retrieval, each image can get a long multimodal explanation for the same question.
# GEMINI_IMAGE_EXPLAIN_API_KEY=your-second-gemini-key
# Optional: override model (default: first generateContent-capable Gemini from the API list)
# GEMINI_IMAGE_EXPLAIN_MODEL=gemini-2.0-flash
# Optional: max output tokens for short image explanations (default 1024)
# MAX_IMAGE_EXPLAIN_TOKENS=1024
#
# Image indexing (optional citation-based embedding when citation is provided at upload)
# IMAGE_CITATION_CONTEXT_LINES=20
# IMAGE_EMBEDDING_INPUT_MAX_CHARS=3500
# Chroma vector distance cap for legacy image vector search (mostly unused; figures are picked by Gemini now)
# RELEVANCE_MAX_DISTANCE_IMAGE=1.45
#
# Fuzzy match Gemini figure strings to uploads (0–100; default 68). Lower = more permissive.
# FIGURE_MATCH_MIN_SCORE=68
